{
  "name": "image-upload-api",
  "version": "1.0.0",
  "description": "Image Upload API - GitHub Classroom Lab",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "format": "prettier --write src/**/*.{ts,js}",
    "typecheck": "tsc --noEmit",
    "test:win": "set NODE_OPTIONS=--experimental-vm-modules&& jest --runInBand"
  },
  "keywords": [
    "file-upload",
    "multer",
    "sharp",
    "image-processing",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "mongoose": "^8.8.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "form-data": "^4.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "mongodb-memory-server": "^10.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
